# Copy this file to .env.local and fill in real values.
# .env.local is gitignored — never commit secrets.

# --- SF Alpha game API ---
GAME_API_BASE=https://api.sf-alpha.com/v2
# Exposed to the browser for client-side login (no secrets, just the base URL)
NEXT_PUBLIC_GAME_API_BASE=https://api.sf-alpha.com/v2

# --- External Anti-Cheat service account (role: External AC) ---
# Used server-side to obtain a bearer token for /v2/auth/ac-detections.
AC_USERNAME=
AC_PASSWORD=

# --- MariaDB (screenshots) ---
DB_HOST=153.92.4.9
DB_PORT=3306
DB_USER=sf_alpha_staff
DB_PASSWORD=
DB_NAME=
# Table that stores screenshots. Columns: unique_id, player_guid, time, data (mediumblob)
DB_SCREENSHOT_TABLE=data

# --- Session cookie (iron-session) ---
# Generate with:  node -e "console.log(require('crypto').randomBytes(32).toString('hex'))"
SESSION_SECRET=

# --- Role gating ---
# role_name value(s) allowed into the dashboard, comma-separated. Case-insensitive.
ALLOWED_ROLES=admin

# --- Sensitive page password ---
# Required to access Top-Up and Whitelist pages. Set any strong password.
SENSITIVE_PAGE_PASSWORD=
